generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String    @id @default(cuid())
  name      String
  gstin     String?
  address   String?
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  panNo     String?
  stateCode String?
  stateName String?
  invoices  Invoice[]
}

model Product {
  id           String        @id @default(cuid())
  name         String
  description  String?
  price        Float
  hsn          String?
  gstRate      Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  discount     Float         @default(0)
  invoiceItems InvoiceItem[]
}

model CompanySettings {
  id           String   @id @default("default")
  companyName  String   @default("Your Company Name")
  address      String?
  gstin        String?
  logoUrl      String?
  upiId        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lutNo        String?
  altPhone     String?
  brandName    String?
  businessType String?
  email        String?
  panNo        String?
  phone        String?
  website      String?
  stateCode    String?   @default("27") // Default to Maharashtra for safety
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique
  rate      Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bank {
  id            String    @id @default(cuid())
  bankName      String
  accountNumber String
  ifsc          String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invoices      Invoice[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  date          DateTime      @default(now())
  dueDate       DateTime?
  status        String        @default("draft")
  subTotal      Float         @default(0)
  taxTotal      Float         @default(0)
  total         Float         @default(0)
  notes         String?
  clientId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bankId        String?
  currency      String        @default("INR")
  discountType  String?
  discountValue Float         @default(0)
  invoiceType   String        @default("REGULAR")
  roundOff      Float         @default(0)
  exchangeRate  Float         @default(1.0)
  paymentMethod String        @default("UPI")
  reference     String?
  bank          Bank?         @relation(fields: [bankId], references: [id])
  client        Client        @relation(fields: [clientId], references: [id])
  items         InvoiceItem[]
}

model InvoiceItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  price     Float
  tax       Float
  invoiceId String
  productId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  vendorName  String
  category    String   @default("SOFTWARE") // SOFTWARE, HARDWARE, RENT, OTHER
  description String?
  totalAmount Float
  taxAmount   Float    @default(0)
  isRcm       Boolean  @default(false)       // Reverse Charge Mechanism
  itcEligible Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
